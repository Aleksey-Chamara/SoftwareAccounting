@{
    ViewData["Title"] = "Вход в систему";
    Layout = null;
    /*
       Страница входа в систему. Использует отдельный макет (Layout = null).
        Содержит форму с полями username/password, выводит ошибку при неудаче.
        Стилизована в виде карточки с иконкой замка.
    */
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Вход - IT Audit System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body { background-color: #f3f4f6; display: flex; align-items: center; justify-content: center; height: 100vh; font-family: 'Inter', sans-serif; }
        .login-card { background: white; padding: 2.5rem; border-radius: 16px; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1); width: 100%; max-width: 400px; }
        .login-header { text-align: center; margin-bottom: 2rem; }
        .login-icon { font-size: 3rem; color: #2563eb; margin-bottom: 1rem; }
        .form-control { padding: 0.75rem; border-radius: 8px; background-color: #f9fafb; border: 1px solid #e5e7eb; }
        .btn-login { width: 100%; padding: 0.75rem; border-radius: 8px; font-weight: 600; background-color: #2563eb; border: none; margin-top: 1rem; }
        .btn-login:hover { background-color: #1d4ed8; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-header">
            <div class="login-icon"><i class="bi bi-shield-lock"></i></div>
            <h3>Вход в систему</h3>
            <p class="text-muted">Введите учетные данные</p>
        </div>
        <form method="post">
            <div class="mb-3">
                <label class="form-label text-muted small fw-bold">ПОЛЬЗОВАТЕЛЬ</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-person"></i></span>
                    <input name="username" class="form-control border-start-0 ps-0" placeholder="admin" required />
                </div>
            </div>
            <div class="mb-4">
                <label class="form-label text-muted small fw-bold">ПАРОЛЬ</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-key"></i></span>
                    <input name="password" type="password" class="form-control border-start-0 ps-0" placeholder="••••••" required />
                </div>
            </div>
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger py-2 text-center small">@ViewBag.Error</div>
            }
            <button type="submit" class="btn btn-primary btn-login">Войти</button>
        </form>
        <div class="text-center mt-4 pt-3 border-top">
            <small class="text-muted">Лабораторная работа | ASP.NET Core</small>
        </div>
    </div>
</body>
</html>