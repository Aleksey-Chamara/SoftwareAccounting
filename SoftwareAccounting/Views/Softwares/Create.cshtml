@model SoftwareAccounting.Models.Software

@{ ViewData["Title"] = "Добавление ПО"; }

<h1>Добавить ПО в справочник</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <label asp-for="License" class="control-label"></label>
                <select asp-for="License" class="form-control" asp-items="Html.GetEnumSelectList<SoftwareAccounting.Models.LicenseType>()"></select>
            </div>
            <div class="form-group mb-3">
                <label asp-for="SoftwareType" class="control-label"></label>
                <input asp-for="SoftwareType" class="form-control" placeholder="Например: OS, Editor, Antivirus" />
            </div>
            <div class="form-group">
                <input type="submit" value="Сохранить" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Назад</a>
            </div>
        </form>
    </div>
</div>