@model SoftwareAccounting.Models.Computer
@{
    ViewData["Title"] = "Добавить компьютер";
    /*
       Форма для добавления нового компьютера (только для администратора).
        Поля: владелец, MAC-адрес, дата последней проверки.

    */
}
<h1>Добавить компьютер</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-3">
                <label asp-for="Owner" class="control-label"></label>
                <input asp-for="Owner" class="form-control" />
                <span asp-validation-for="Owner" class="text-danger"></span>
            </div>           
            <div class="form-group mb-3">
                <label asp-for="MacAddress" class="control-label"></label>
                <input asp-for="MacAddress" class="form-control" />
                <span asp-validation-for="MacAddress" class="text-danger"></span>
            </div>          
            <div class="form-group mb-3">
                <label asp-for="LastCheckDate" class="control-label"></label>
                <input asp-for="LastCheckDate" class="form-control" />
                <span asp-validation-for="LastCheckDate" class="text-danger"></span>
            </div>         
            <div class="form-group">
                <input type="submit" value="Создать" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Назад</a>
            </div>
        </form>
    </div>
</div>
@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}